model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(TENANT)
  status    Status   @default(ACTIVE)
  phone     String?  @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]

  rentalRequests RentalRequest[]

  reviews Review[]

  @@map("users")
}
